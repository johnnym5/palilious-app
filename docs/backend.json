{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile for the ControlFlow app.",
      "properties": {
        "orgId": {
          "type": "string",
          "description": "The ID of the organization the user belongs to."
        },
        "username": {
          "type": "string",
          "description": "User's unique username."
        },
        "displayName": {
          "type": "string",
          "description": "User's display name."
        },
        "position": {
          "type": "string",
          "description": "The user's job position within the organization.",
          "enum": ["Staff", "HR Manager", "Finance Manager", "Managing Director", "Organization Administrator"]
        },
        "status": {
          "type": "string",
          "enum": [
            "ONLINE",
            "OFFLINE"
          ],
          "description": "User's current status."
        },
        "notificationPreferences": {
          "type": "object",
          "description": "User's notification settings.",
          "properties": {
            "requisitionUpdates": {
              "type": "boolean"
            },
            "taskAssignments": {
              "type": "boolean"
            },
            "announcements": {
              "type": "boolean"
            }
          }
        }
      },
      "required": [
        "orgId",
        "username",
        "displayName",
        "position"
      ]
    },
    "Attendance": {
      "title": "Attendance",
      "type": "object",
      "description": "Represents a single attendance record for a user.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user."
        },
        "userName": {
            "type": "string",
            "description": "The name of the user who clocked in."
        },
        "orgId": {
          "type": "string",
          "description": "The ID of the organization."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the attendance record in YYYY-MM-DD format."
        },
        "clockIn": {
          "type": "string",
          "format": "date-time",
          "description": "The ISO timestamp when the user clocked in."
        },
        "clockOut": {
          "type": "string",
          "format": "date-time",
          "description": "The ISO timestamp when the user clocked out."
        },
        "status": {
            "type": "string",
            "enum": ["PENDING", "APPROVED", "REJECTED"],
            "description": "The approval status of the clock-in record."
        },
        "approvedBy": {
            "type": "string",
            "description": "The ID of the user who approved or rejected the record."
        },
        "approvedAt": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp of the approval or rejection."
        }
      },
      "required": [
        "userId",
        "userName",
        "orgId",
        "date",
        "clockIn",
        "status"
      ]
    },
    "Requisition": {
      "title": "Requisition",
      "type": "object",
      "description": "Represents a single financial requisition.",
      "properties": {
        "serialNo": { "type": "string", "description": "The requisition's unique serial number (e.g., REQ-0001)." },
        "orgId": { "type": "string", "description": "The ID of the organization." },
        "createdBy": { "type": "string", "description": "The user ID of the creator." },
        "creatorName": { "type": "string", "description": "The name of the user who created the request." },
        "title": { "type": "string", "description": "The title of the requisition." },
        "amount": { "type": "number", "description": "The requisition amount." },
        "description": { "type": "string", "description": "A detailed description of the requisition." },
        "attachmentUrl": { "type": "string", "format": "uri", "description": "URL of any attachment." },
        "status": {
            "type": "string",
            "enum": ["PENDING_HR", "PENDING_FINANCE", "PENDING_MD", "APPROVED", "PAID", "REJECTED"],
            "description": "The current status of the requisition."
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "approvalHistory": {
            "type": "array",
            "description": "A log of all status changes.",
            "items": {
                "type": "object",
                "properties": {
                    "actorId": { "type": "string", "description": "The user ID of the person who made the change." },
                    "actorName": { "type": "string", "description": "The name of the person who made the change." },
                    "actorPosition": { "type": "string", "description": "The position of the user who made the change." },
                    "action": { "type": "string", "enum": ["CREATED", "APPROVED", "REJECTED", "PAID"]},
                    "timestamp": { "type": "string", "format": "date-time" },
                    "fromStatus": { "type": "string" },
                    "toStatus": { "type": "string" },
                    "reason": { "type": "string", "description": "Reason for rejection, if applicable." }
                },
                "required": ["actorId", "actorName", "actorPosition", "action", "timestamp", "fromStatus", "toStatus"]
            }
        }
      },
      "required": ["serialNo", "orgId", "createdBy", "creatorName", "title", "amount", "description", "status", "createdAt", "approvalHistory"]
    },
     "Task": {
      "title": "Task",
      "type": "object",
      "description": "Represents a single assignable task.",
      "properties": {
        "orgId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string", "description": "The user ID of the assignee." },
        "assignedToName": { "type": "string", "description": "The name of the assignee." },
        "priority": { "type": "string", "enum": ["CRITICAL", "OPERATIONAL", "ROUTINE"] },
        "status": { "type": "string", "enum": ["QUEUED", "ACTIVE", "AWAITING_REVIEW", "ARCHIVED"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string", "description": "The user ID of the creator." },
        "updates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "time": { "type": "string", "format": "date-time" },
              "updatedBy": { "type": "string" },
              "note": { "type": "string" }
            },
            "required": ["status", "time", "updatedBy"]
          }
        }
      },
      "required": [
        "orgId",
        "title",
        "assignedTo",
        "assignedToName",
        "priority",
        "status",
        "dueDate",
        "createdBy",
        "updates"
      ]
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "type": "object",
      "description": "Stores system-wide configuration toggles for an organization.",
      "properties": {
        "orgId": {
          "type": "string",
          "description": "The ID of the organization this config applies to."
        },
        "finance_access": {
          "type": "boolean",
          "description": "Toggles visibility of the Requisitions module."
        },
        "admin_tools": {
          "type": "boolean",
          "description": "Toggles visibility of the Team Management module for non-admins."
        },
        "attendance_strict": {
          "type": "boolean",
          "description": "Toggles strict mode for attendance (e.g., Geofencing)."
        }
      },
      "required": [
        "orgId",
        "finance_access",
        "admin_tools",
        "attendance_strict"
      ]
    },
    "Chat": {
        "title": "Chat",
        "type": "object",
        "description": "Represents a chat conversation between two or more users.",
        "properties": {
            "orgId": { "type": "string" },
            "participants": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Array of user IDs participating in the chat."
            },
            "participantProfiles": {
                "type": "object"
            },
            "lastMessage": {
                "type": "object",
                "properties": {
                    "text": { "type": "string" },
                    "senderId": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" }
                }
            },
            "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["orgId", "participants", "participantProfiles", "updatedAt"]
    },
    "ChatMessage": {
        "title": "ChatMessage",
        "type": "object",
        "description": "Represents a single message within a chat.",
        "properties": {
            "chatId": { "type": "string" },
            "orgId": { "type": "string" },
            "senderId": { "type": "string" },
            "content": { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["chatId", "orgId", "senderId", "content", "timestamp"]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/entities/UserProfile"
          },
          "description": "Stores user profiles for the ControlFlow app.",
          "params": [
            {
              "name": "userId",
              "description": "The user's unique ID."
            }
          ]
        }
      },
      {
        "path": "/attendance/{attendanceId}",
        "definition": {
          "entityName": "Attendance",
          "schema": {
            "$ref": "#/entities/Attendance"
          },
          "description": "Stores user attendance records.",
          "params": [
            {
              "name": "attendanceId",
              "description": "The attendance record's unique ID."
            }
          ]
        }
      },
      {
        "path": "/requisitions/{requisitionId}",
        "definition": {
          "entityName": "Requisition",
          "schema": {
            "$ref": "#/entities/Requisition"
          },
          "description": "Stores financial requisition requests.",
          "params": [
            {
              "name": "requisitionId",
              "description": "The requisition's unique ID."
            }
          ]
        }
      },
      {
        "path": "/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "schema": {
            "$ref": "#/entities/Task"
          },
          "description": "Stores tasks assigned to users.",
          "params": [
            {
              "name": "taskId",
              "description": "The task's unique ID."
            }
          ]
        }
      },
      {
        "path": "/system_configs/{configId}",
        "definition": {
          "entityName": "SystemConfig",
          "schema": {
            "$ref": "#/entities/SystemConfig"
          },
          "description": "Stores feature toggle configurations for each organization.",
          "params": [
            {
              "name": "configId",
              "description": "The unique ID for the configuration document."
            }
          ]
        }
      },
      {
        "path": "/chats/{chatId}",
        "definition": {
            "entityName": "Chat",
            "schema": {
            "$ref": "#/entities/Chat"
            },
            "description": "Stores chat conversations.",
            "params": [
            {
                "name": "chatId",
                "description": "The chat's unique ID."
            }
            ]
        }
    },
    {
        "path": "/chats/{chatId}/messages/{messageId}",
        "definition": {
            "entityName": "ChatMessage",
            "schema": {
            "$ref": "#/entities/ChatMessage"
            },
            "description": "Stores messages for a specific chat.",
            "params": [
            {
                "name": "chatId",
                "description": "The chat's unique ID."
            },
            {
                "name": "messageId",
                "description": "The message's unique ID."
            }
            ]
        }
    }
    ]
  }
}
