rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      // Use exists() to prevent errors on new user creation before profile exists
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : '';
    }

    function isRole(role) {
      return isSignedIn() && getUserRole() == role;
    }

    function isOneOfRoles(roles) {
      return isSignedIn() && getUserRole() in roles;
    }
    
    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------

    /**
     * @description User profiles. A user can update their own profile.
     * HR/MD roles can read, create, update, and delete all profiles. 
     * All signed-in users can read basic info.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isOneOfRoles(['HR', 'MD']);
      allow create: if isOneOfRoles(['HR', 'MD']);
      allow update: if isOwner(userId) || isOneOfRoles(['HR', 'MD']);
      allow delete: if isOneOfRoles(['HR', 'MD']);
    }

    /**
     * @description Attendance records. Users can manage their own records.
     * HR/MD roles can read all records.
     * @path /attendance/{attendanceId}
     */
    match /attendance/{attendanceId} {
      allow get: if isOwner(resource.data.userId) || isOneOfRoles(['HR', 'MD']);
      allow list: if isSignedIn(); // Relies on client-side queries
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    /**
     * @description Financial requisitions. The creator can view.
     * HR, Finance, and MD roles can access based on their function.
     * @path /requisitions/{reqId}
     */
    match /requisitions/{reqId} {
      allow get: if isOwner(resource.data.createdBy) || isOneOfRoles(['HR', 'FINANCE', 'MD']);
      allow list: if isSignedIn(); // Relies on client-side queries
      allow create: if isOwner(request.resource.data.createdBy);
      allow update: if isOwner(resource.data.createdBy) || isOneOfRoles(['HR', 'FINANCE', 'MD']);
      allow delete: if isRole('MD');
    }

    /**
     * @description Tasks. The creator and assignee can read/update.
     * HR/MD roles can view all tasks for oversight.
     * @path /tasks/{taskId}
     */
    match /tasks/{taskId} {
      allow get: if isOwner(resource.data.assignedTo) || isOwner(resource.data.createdBy) || isOneOfRoles(['HR', 'MD']);
      allow list: if isSignedIn(); // Relies on client-side queries
      allow create: if isOwner(request.resource.data.createdBy);
      allow update: if isOwner(resource.data.assignedTo) || isOwner(resource.data.createdBy) || isOneOfRoles(['HR', 'MD']);
      allow delete: if isOwner(resource.data.createdBy) || isOneOfRoles(['HR', 'MD']);
    }

    /**
     * @description Company-wide announcements. Readable by all, writable by HR.
     * @path /announcements/{postId}
     */
    match /announcements/{postId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isRole('HR');
    }

    /**
     * @description Chat conversations. Only participants can access.
     * @path /chats/{chatId}
     */
    match /chats/{chatId} {
      allow get, update: if request.auth.uid in resource.data.participants;
      allow list: if isSignedIn(); // Relies on client-side queries
      allow create: if request.auth.uid in request.resource.data.participants;
      allow delete: if false;

      /**
       * @description Messages within a chat. Only participants can read.
       * Only the sender can create/edit/delete their messages.
       * @path /chats/{chatId}/messages/{messageId}
       */
      match /messages/{messageId} {
        allow get, list: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isOwner(request.resource.data.senderId) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow update, delete: if isOwner(resource.data.senderId);
      }
    }
  }
}
